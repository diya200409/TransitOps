# TransitOps Backend Configuration
# Copy this file to .env and fill in your actual values

# ==============================================================================
# REQUIRED FOR PRODUCTION
# ==============================================================================

# Secret key for JWT token signing (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TRANSITOPS_SECRET_KEY=your-secure-random-key-here-change-this

# Allowed CORS origins (comma-separated)
# For production, specify your frontend domain(s)
TRANSITOPS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==============================================================================
# JWT CONFIGURATION
# ==============================================================================

# JWT algorithm (default: HS256)
TRANSITOPS_JWT_ALGORITHM=HS256

# Access token expiry in hours (default: 12)
TRANSITOPS_ACCESS_TOKEN_EXPIRE_HOURS=12

# ==============================================================================
# SIGNUP RESTRICTIONS
# ==============================================================================

# Allow public signup for privileged roles (fleet_manager, safety_officer, etc.)
# Set to "true" only for demos or trusted environments
# For production, keep "false" and create admin users via seed.py
TRANSITOPS_ALLOW_PUBLIC_PRIVILEGED_SIGNUP=false

# ==============================================================================
# EMAIL CONFIGURATION (Optional - for license expiry notifications)
# ==============================================================================

# SMTP server configuration
TRANSITOPS_SMTP_HOST=smtp.gmail.com
TRANSITOPS_SMTP_PORT=587
TRANSITOPS_SMTP_USER=your-email@gmail.com
TRANSITOPS_SMTP_PASSWORD=your-app-specific-password
TRANSITOPS_SMTP_FROM=noreply@yourdomain.com
TRANSITOPS_SMTP_USE_TLS=true

# ==============================================================================
# DEVELOPMENT SETTINGS
# ==============================================================================

# For local development, you can use these values:
# TRANSITOPS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# TRANSITOPS_ALLOW_PUBLIC_PRIVILEGED_SIGNUP=true
